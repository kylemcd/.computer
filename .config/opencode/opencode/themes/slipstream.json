{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black":       "#000000",
    "bg1":         "#060606",
    "bg2":         "#0a0a0a",
    "bg3":         "#121212",
    "border":      "#141414",
    "border2":     "#1a1a1a",
    "fg":          "#e2e2e6",
    "fgMuted":     "#8e8e96",
    "fgSubtle":    "#5c5c64",
    "fgDisabled":  "#44444a",
    "teal":        "#5cb8a2",
    "tealBright":  "#7cd4be",
    "tealDim":     "#4a9a86",
    "gold":        "#f4d58d",
    "goldBright":  "#fae4b0",
    "sky":         "#8cb8dc",
    "blue":        "#7aa4c9",
    "rose":        "#e85c6c",
    "roseBright":  "#ff7a8a"
  },
  "theme": {
    "primary":     { "dark": "teal",       "light": "teal" },
    "secondary":   { "dark": "sky",        "light": "sky" },
    "accent":      { "dark": "tealBright", "light": "tealBright" },
    "error":       { "dark": "rose",       "light": "rose" },
    "warning":     { "dark": "gold",       "light": "gold" },
    "success":     { "dark": "teal",       "light": "teal" },
    "info":        { "dark": "blue",       "light": "blue" },

    "text":              { "dark": "fg",          "light": "fg" },
    "textMuted":         { "dark": "fgMuted",     "light": "fgMuted" },
    "background":        { "dark": "black",       "light": "black" },
    "backgroundPanel":   { "dark": "bg1",         "light": "bg1" },
    "backgroundElement": { "dark": "bg2",         "light": "bg2" },
    "border":            { "dark": "border",      "light": "border" },
    "borderActive":      { "dark": "teal",        "light": "teal" },
    "borderSubtle":      { "dark": "border2",     "light": "border2" },

    "diffAdded":              { "dark": "teal",       "light": "teal" },
    "diffRemoved":            { "dark": "rose",       "light": "rose" },
    "diffContext":            { "dark": "fgSubtle",   "light": "fgSubtle" },
    "diffHunkHeader":         { "dark": "fgSubtle",   "light": "fgSubtle" },
    "diffHighlightAdded":     { "dark": "tealBright", "light": "tealBright" },
    "diffHighlightRemoved":   { "dark": "roseBright", "light": "roseBright" },
    "diffAddedBg":            { "dark": "#060f0d",    "light": "#060f0d" },
    "diffRemovedBg":          { "dark": "#0f0607",    "light": "#0f0607" },
    "diffContextBg":          { "dark": "bg1",        "light": "bg1" },
    "diffLineNumber":         { "dark": "fgDisabled", "light": "fgDisabled" },
    "diffAddedLineNumberBg":  { "dark": "#060f0d",    "light": "#060f0d" },
    "diffRemovedLineNumberBg":{ "dark": "#0f0607",    "light": "#0f0607" },

    "markdownText":            { "dark": "fg",         "light": "fg" },
    "markdownHeading":         { "dark": "teal",       "light": "teal" },
    "markdownLink":            { "dark": "sky",        "light": "sky" },
    "markdownLinkText":        { "dark": "tealBright", "light": "tealBright" },
    "markdownCode":            { "dark": "gold",       "light": "gold" },
    "markdownBlockQuote":      { "dark": "fgSubtle",   "light": "fgSubtle" },
    "markdownEmph":            { "dark": "gold",       "light": "gold" },
    "markdownStrong":          { "dark": "fg",         "light": "fg" },
    "markdownHorizontalRule":  { "dark": "border2",    "light": "border2" },
    "markdownListItem":        { "dark": "teal",       "light": "teal" },
    "markdownListEnumeration": { "dark": "tealDim",    "light": "tealDim" },
    "markdownImage":           { "dark": "sky",        "light": "sky" },
    "markdownImageText":       { "dark": "tealBright", "light": "tealBright" },
    "markdownCodeBlock":       { "dark": "fg",         "light": "fg" },

    "syntaxComment":     { "dark": "fgSubtle",  "light": "fgSubtle" },
    "syntaxKeyword":     { "dark": "sky",       "light": "sky" },
    "syntaxFunction":    { "dark": "teal",      "light": "teal" },
    "syntaxVariable":    { "dark": "fg",        "light": "fg" },
    "syntaxString":      { "dark": "gold",      "light": "gold" },
    "syntaxNumber":      { "dark": "gold",      "light": "gold" },
    "syntaxType":        { "dark": "sky",       "light": "sky" },
    "syntaxOperator":    { "dark": "fgMuted",   "light": "fgMuted" },
    "syntaxPunctuation": { "dark": "fgMuted",   "light": "fgMuted" }
  }
}
