{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#19100E",
          "foreground": "#EC5B2B",
          "leading_diamond": "",
          "style": "diamond",
          "template": "{{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "#19100E",
          "foreground": "#EC5B2B",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#19100E",
          "foreground": "#EC5B2B",
          "options": {
            "branch_icon": ""
          },
          "style": "plain",
          "template": " git({{ .HEAD }}) ",
          "type": "git"
        },
        {
          "background": "#19100E",
          "foreground": "#EC5B2B",
          "options": {
            "time_format": "3:04 PM"
          },
          "style": "diamond",
          "template": " {{ .CurrentDate | date .Format }}",
          "trailing_diamond": "",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#EC5B2B",
          "style": "plain",
          "template": "❯",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
